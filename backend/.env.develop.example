# Django local development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=change-me-for-local-development

# Frontend / CORS
CORS_ALLOW_ALL_ORIGINS=true
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# Default local mode uses SQLite, so `python manage.py runserver` works
# without Docker. To use local Docker Postgres, set DB_ENGINE=postgres and
# keep POSTGRES_HOST=127.0.0.1 / POSTGRES_PORT=5433.
DB_ENGINE=sqlite
POSTGRES_DB=tox_db
POSTGRES_USER=tox_user
POSTGRES_PASSWORD=tox_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Email OTP / Resend
RESEND_API_KEY=re_your_resend_api_key
DEFAULT_FROM_EMAIL=ToxicWaste <onboarding@resend.dev>
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# External APIs
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

# Local media / MinIO
# Keep USE_S3=false for the simplest runserver workflow. Set USE_S3=true only
# after starting the local MinIO services with `docker compose up -d minio minio-init`.
USE_S3=false
AWS_ACCESS_KEY_ID=tox_minio_admin
AWS_SECRET_ACCESS_KEY=tox_minio_password
AWS_STORAGE_BUCKET_NAME=tox-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9000
AWS_S3_ADDRESSING_STYLE=path
AWS_QUERYSTRING_AUTH=false
AWS_S3_FILE_OVERWRITE=true
AWS_S3_URL_PROTOCOL=http:
AWS_S3_CUSTOM_DOMAIN=127.0.0.1:9000/tox-media
