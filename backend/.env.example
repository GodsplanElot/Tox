DJANGO_SECRET_KEY=django-insecure-development-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Third-party integrations (optional for local dev)
TMDB_API_KEY=

# AWS S3 (optional; only needed if you enable S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# CORS (dev default allows all)
CORS_ALLOW_ALL_ORIGINS=true

