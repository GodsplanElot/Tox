# Django
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.toxicreels.com,YOUR_LIGHTSAIL_STATIC_IP
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# Frontend / CORS / CSRF
FRONTEND_URL=https://toxicreels.com
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=https://toxicreels.com,https://www.toxicreels.com
CORS_ALLOW_CREDENTIALS=false
CSRF_TRUSTED_ORIGINS=https://toxicreels.com,https://www.toxicreels.com,https://api.toxicreels.com

# HTTPS behind Nginx / Cloudflare
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false
X_FRAME_OPTIONS=DENY

# Database
DB_ENGINE=postgres
POSTGRES_DB=tox_db
POSTGRES_USER=tox_user
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Email OTP / Resend
RESEND_API_KEY=re_your_resend_api_key
DEFAULT_FROM_EMAIL=ToxicReels <noreply@toxicreels.com>
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# External APIs
TMDB_API_KEY=your-tmdb-api-key

# AWS S3 media storage
USE_S3=true
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-production-s3-bucket
AWS_S3_REGION_NAME=eu-west-3
AWS_S3_ENDPOINT_URL=
AWS_S3_ADDRESSING_STYLE=virtual
AWS_QUERYSTRING_AUTH=false
AWS_S3_FILE_OVERWRITE=false
AWS_S3_URL_PROTOCOL=https:
AWS_S3_CUSTOM_DOMAIN=
